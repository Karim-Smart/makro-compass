{
  "name": "makro-compass",
  "version": "0.1.0",
  "description": "maKro Compass — AI coaching overlay for League of Legends",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "gen:tray-icon": "node scripts/generate-tray-icon.cjs"
  },
  "keywords": [
    "electron",
    "react",
    "league-of-legends",
    "coaching",
    "overlay"
  ],
  "author": "Karim",
  "license": "MIT",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^27.3.11",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.7.9",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "build": {
    "appId": "com.makrocompass.app",
    "productName": "maKro Compass",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  }
}
